# Unpackfs module config for PallasOS
unpack:
    -   source: /run/archiso/bootmnt/pallas/x86_64/airootfs.sfs
        sourcefs: erofs
        destination: ""
    -   source: /run/archiso/bootmnt/pallas/boot/x86_64/vmlinuz-linux
        sourcefs: file
        destination: "/boot/vmlinuz-linux"
    -   source: /run/archiso/bootmnt/pallas/boot/intel-ucode.img
        sourcefs: file
        destination: "/boot/intel-ucode.img"
    -   source: /run/archiso/bootmnt/pallas/boot/amd-ucode.img
        sourcefs: file
        destination: "/boot/amd-ucode.img"
