[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = plymouth

[Action]
Description = Applying PallasOS Plymouth branding...
When = PostTransaction
Exec = /bin/sh -c 'cp -f /etc/plymouth/pallas-logo.png /usr/share/plymouth/themes/spinner/watermark.png && cp -f /etc/plymouth/pallas-spinner.plymouth /usr/share/plymouth/themes/spinner/spinner.plymouth'
