#!/bin/bash
# Launch Calamares and capture errors
LOG="/tmp/calamares-error.log"
export QT_QPA_PLATFORMTHEME=kde
export QT_STYLE_OVERRIDE=Breeze-Dark
export QT_QUICK_CONTROLS_STYLE=org.kde.desktop
calamares 2>&1 | tee "$LOG"
EXIT_CODE=${PIPESTATUS[0]}

if [ $EXIT_CODE -ne 0 ]; then
    # Show error to user if calamares crashed
    if command -v kdialog &>/dev/null; then
        kdialog --error "Calamares gagal dibuka.\n\nError:\n$(tail -20 $LOG)" --title "PallasOS Installer Error"
    elif command -v xmessage &>/dev/null; then
        xmessage -center "Calamares gagal dibuka. Lihat $LOG"
    fi
    echo -e "\nTekan ENTER untuk menutup..."
    read
fi
