#!/bin/bash

# Setup Live User 'pallas' for Autologin
if ! id -u pallas >/dev/null 2>&1; then
    # Create autologin group if it doesn't exist (LightDM requirement)
    groupadd -r autologin 2>/dev/null || true
    
    useradd -m -g users -G wheel,video,audio,storage,optical -s /bin/bash pallas
    
    # Set empty password
    passwd -d pallas
    
    # Allow passwordless sudo for wheel group
    echo "%wheel ALL=(ALL:ALL) NOPASSWD: ALL" > /etc/sudoers.d/99-pallas-wheel
    chmod 0440 /etc/sudoers.d/99-pallas-wheel
fi

# Enable SDDM if not enabled
systemctl enable sddm 2>/dev/null || true
