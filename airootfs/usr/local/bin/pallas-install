#!/bin/bash
# ============================================================
#  PallasOS GUI Installer
# ============================================================

if [[ $EUID -ne 0 ]]; then
    yad --error --title="PallasOS Installer" --text="Installer harus dijalankan sebagai root (Gunakan sudo)!" --button="OK:0"
    exit 1
fi

if ! command -v yad &> /dev/null; then
    echo "YAD tidak ditemukan. Menjalankan installer CLI..."
    exec pallas-install-cli
fi

# Gather data
DISKS=$(lsblk -d -p -n -o NAME,SIZE,TYPE | grep "disk" | awk '{print $1" ("$2")"}' | paste -sd '!' -)
if [[ -z "$DISKS" ]]; then
    yad --error --title="Error" --text="Tidak ada disk yang ditemukan!"
    exit 1
fi

TIMEZONES="Asia/Jakarta!America/New_York!Europe/London!UTC"

# Run Yad Form
FORM_DATA=$(yad --title="PallasOS Installer - Welcome" \
    --window-icon="drive-harddisk" \
    --image="/usr/share/pixmaps/pallasos-logo.png" \
    --image-on-top \
    --text="<span font='14' weight='bold'>PallasOS Installer</span>\nSilakan lengkapi konfigurasi instalasi PallasOS di bawah ini:" \
    --form --columns=2 \
    --separator="|" \
    --width=750 \
    --borders=15 \
    --field="Target Disk:CB" "$DISKS" \
    --field="Timezone:CB" "$TIMEZONES" \
    --field="Locale:CB" "en_US.UTF-8!id_ID.UTF-8" \
    --field="Keymap:CB" "us!uk" \
    --field="Hostname:" "pallas" \
    --field="Username:" "pallas" \
    --field="Password (User):H" "" \
    --field="Password (Root):H" "" \
    --field="Swap (GB):NUM" "2!0..64!1" \
    --button="Batal:1" --button="Mulai Instalasi:0")

if [[ $? -ne 0 ]]; then
    exit 0
fi

# Parse output
export TARGET_DISK=$(echo "$FORM_DATA" | awk -F '|' '{print $1}' | awk '{print $1}')
export TIMEZONE=$(echo "$FORM_DATA" | awk -F '|' '{print $2}')
export LOCALE=$(echo "$FORM_DATA" | awk -F '|' '{print $3}')
export KEYMAP=$(echo "$FORM_DATA" | awk -F '|' '{print $4}')
export HOSTNAME_VAL=$(echo "$FORM_DATA" | awk -F '|' '{print $5}')
export USERNAME=$(echo "$FORM_DATA" | awk -F '|' '{print $6}')
export USER_PASS=$(echo "$FORM_DATA" | awk -F '|' '{print $7}')
export ROOT_PASS=$(echo "$FORM_DATA" | awk -F '|' '{print $8}')
export SWAP_SIZE=$(echo "$FORM_DATA" | awk -F '|' '{print $9}' | awk -F '[,.]' '{print $1}')
export AUTO_INSTALL=1

# Validate inputs
if [[ -z "$USERNAME" || -z "$USER_PASS" || -z "$ROOT_PASS" || -z "$HOSTNAME_VAL" ]]; then
    yad --error --title="Error" --text="Semua kolom harus diisi!"
    exec $0
fi

yad --question --title="Konfirmasi" --text="PERINGATAN: Semua data di <b>$TARGET_DISK</b> akan DIHAPUS!\n\nLanjutkan instalasi?" --button="Batal:1" --button="Ya, Hapus Data:0"
if [[ $? -ne 0 ]]; then
    exit 0
fi

# Run CLI installer in background and pipe output to Yad
pallas-install-cli 2>&1 | tee /tmp/pallas-install.log | stdbuf -oL tr '\r' '\n' | yad --text-info \
    --tail \
    --title="Menginstall PallasOS..." \
    --text="Proses instalasi sedang berjalan. Silakan pantau log di bawah ini:" \
    --width=700 --height=500 \
    --button="Tutup:0"

if [[ ${PIPESTATUS[0]} -eq 0 ]]; then
    yad --info --title="Instalasi Selesai" --text="PallasOS berhasil diinstall!\nSilakan cabut flashdisk dan restart komputer Anda." --button="Reboot Sekarang:0" --button="Nanti:1"
    if [[ $? -eq 0 ]]; then
        reboot
    fi
else
    yad --error --title="Instalasi Gagal" --text="Terjadi kesalahan saat menginstall PallasOS.\nSilakan cek log di <b>/tmp/pallas-install.log</b> untuk detail lebih lanjut."
fi
